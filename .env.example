# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# SSH target: user@hostname or user@ip-address
SERVER=root@your-server-ip

# Directory on the remote server where the app will live
REMOTE_DIR=/opt/ted-linda-stories

# Host port to expose the web server on
PORT=80

# Container name
CONTAINER_NAME=ted-linda-stories
