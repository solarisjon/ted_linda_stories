# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# SSH target: user@hostname or user@ip-address
SERVER=root@your-server-ip

# Directory on the remote server where the app will live
REMOTE_DIR=/opt/ted-linda-stories

# Host port to expose the web server on
PORT=80

# Container name
CONTAINER_NAME=ted-linda-stories

# Flask session secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Password to access /admin/upload
ADMIN_PASSWORD=change-me-to-a-strong-password
